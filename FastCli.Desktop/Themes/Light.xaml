<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 背景与面板 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FAFAFB" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#E5E7EB" />
    
    <!-- 文本 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4B5563" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#9CA3AF" />
    
    <!-- 控件输入框等 -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F9FAFB" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ControlFocusedBorderBrush" Color="#3B82F6" />
    
    <!-- 选中态 -->
    <SolidColorBrush x:Key="SelectedItemBackgroundBrush" Color="#EFF6FF" />
    <SolidColorBrush x:Key="SelectedItemBorderBrush" Color="#BFDBFE" />
    
    <!-- 主操作按钮 (蓝色系) -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#333333" />

    <!-- 次要按钮 (跟随控制) -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#111827" />
    
    <!-- 危险操作按钮 (红色系) -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#B91C1C" />
    
    <!-- 警告/执行中 (琥珀色) -->
    <SolidColorBrush x:Key="WarningButtonBackgroundBrush" Color="#D97706" />

    <!-- 终端背景与文字 -->
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TerminalTextBrush" Color="#111827" />
</ResourceDictionary>
