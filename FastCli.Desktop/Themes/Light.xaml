<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 背景与面板 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F6F8" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FCFDFE" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#DEE3EA" />
    
    <!-- 文本 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4B5563" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#7C8796" />
    
    <!-- 控件输入框等 -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F6F8FA" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D2D8E0" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#EDF2F7" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#E5EBF2" />
    <SolidColorBrush x:Key="ControlFocusedBorderBrush" Color="#4C6C96" />
    
    <!-- 选中态 -->
    <SolidColorBrush x:Key="SelectedItemBackgroundBrush" Color="#EAF0F8" />
    <SolidColorBrush x:Key="SelectedItemBorderBrush" Color="#9CB3D1" />
    
    <!-- 主操作按钮 (蓝色系) -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#11151B" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#1A2230" />

    <!-- 次要按钮 (跟随控制) -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#E8EDF2" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#DCE4EC" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#111827" />
    
    <!-- 危险操作按钮 (红色系) -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#B91C1C" />
    
    <!-- 警告/执行中 (琥珀色) -->
    <SolidColorBrush x:Key="WarningButtonBackgroundBrush" Color="#D97706" />

    <!-- 终端背景与文字 -->
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TerminalTextBrush" Color="#111827" />

    <!-- ANSI 标准颜色 -->
    <SolidColorBrush x:Key="AnsiBlack" Color="#000000" />
    <SolidColorBrush x:Key="AnsiRed" Color="#DC2626" />
    <SolidColorBrush x:Key="AnsiGreen" Color="#16A34A" />
    <SolidColorBrush x:Key="AnsiYellow" Color="#CA8A04" />
    <SolidColorBrush x:Key="AnsiBlue" Color="#2563EB" />
    <SolidColorBrush x:Key="AnsiMagenta" Color="#9333EA" />
    <SolidColorBrush x:Key="AnsiCyan" Color="#0891B2" />
    <SolidColorBrush x:Key="AnsiWhite" Color="#111827" />
    <SolidColorBrush x:Key="AnsiBrightBlack" Color="#6B7280" />
    <SolidColorBrush x:Key="AnsiBrightRed" Color="#EF4444" />
    <SolidColorBrush x:Key="AnsiBrightGreen" Color="#22C55E" />
    <SolidColorBrush x:Key="AnsiBrightYellow" Color="#EAB308" />
    <SolidColorBrush x:Key="AnsiBrightBlue" Color="#3B82F6" />
    <SolidColorBrush x:Key="AnsiBrightMagenta" Color="#A855F7" />
    <SolidColorBrush x:Key="AnsiBrightCyan" Color="#06B6D4" />
    <SolidColorBrush x:Key="AnsiBrightWhite" Color="#000000" />
</ResourceDictionary>
