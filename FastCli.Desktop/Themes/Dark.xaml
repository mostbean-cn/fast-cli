<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 背景与面板 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0F1115" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#14181C" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#181C20" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#2A3038" />
    
    <!-- 文本 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FA" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A5AEB8" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6D7682" />
    
    <!-- 控件输入框等 -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#20252C" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#313844" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#282F37" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#323A44" />
    <SolidColorBrush x:Key="ControlFocusedBorderBrush" Color="#6E8CB7" />
    
    <!-- 选中态 -->
    <SolidColorBrush x:Key="SelectedItemBackgroundBrush" Color="#1E2734" />
    <SolidColorBrush x:Key="SelectedItemBorderBrush" Color="#5C789D" />
    
    <!-- 主操作按钮 (蓝色系) -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#D1D8E2" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#11151B" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#E0E5EC" />

    <!-- 次要按钮 (跟随控制) -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#252B33" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#303741" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#F5F7FA" />
    <SolidColorBrush x:Key="ImmersiveTerminalBadgeBrush" Color="#20252C" />
    <SolidColorBrush x:Key="ImmersiveTerminalBadgeActiveBrush" Color="#5C3A1B" />
    <SolidColorBrush x:Key="ImmersiveTerminalBadgeActiveForegroundBrush" Color="#FFD4A3" />
    
    <!-- 危险操作按钮 (红色系) -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#D75B66" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#E06C76" />
    
    <!-- 警告/执行中 (琥珀色) -->
    <SolidColorBrush x:Key="WarningButtonBackgroundBrush" Color="#C89235" />

    <!-- 终端背景与文字 -->
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#0C1117" />
    <SolidColorBrush x:Key="TerminalTextBrush" Color="#E4E9F0" />

    <!-- ANSI 标准颜色 -->
    <SolidColorBrush x:Key="AnsiBlack" Color="#000000" />
    <SolidColorBrush x:Key="AnsiRed" Color="#FF6B6B" />
    <SolidColorBrush x:Key="AnsiGreen" Color="#69DB7C" />
    <SolidColorBrush x:Key="AnsiYellow" Color="#FFD93D" />
    <SolidColorBrush x:Key="AnsiBlue" Color="#4DABF7" />
    <SolidColorBrush x:Key="AnsiMagenta" Color="#DA77F2" />
    <SolidColorBrush x:Key="AnsiCyan" Color="#38D9A9" />
    <SolidColorBrush x:Key="AnsiWhite" Color="#E6EDF3" />
    <SolidColorBrush x:Key="AnsiBrightBlack" Color="#495057" />
    <SolidColorBrush x:Key="AnsiBrightRed" Color="#FF8787" />
    <SolidColorBrush x:Key="AnsiBrightGreen" Color="#8CE99A" />
    <SolidColorBrush x:Key="AnsiBrightYellow" Color="#FFE066" />
    <SolidColorBrush x:Key="AnsiBrightBlue" Color="#74C0FC" />
    <SolidColorBrush x:Key="AnsiBrightMagenta" Color="#E599F7" />
    <SolidColorBrush x:Key="AnsiBrightCyan" Color="#63E6BE" />
    <SolidColorBrush x:Key="AnsiBrightWhite" Color="#FFFFFF" />
</ResourceDictionary>
