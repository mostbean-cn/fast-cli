<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 背景与面板 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#18181A" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#202022" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#363639" />
    
    <!-- 文本 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#6B7280" />
    
    <!-- 控件输入框等 -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2B2B2D" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#404044" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#363639" />
    <SolidColorBrush x:Key="ControlFocusedBorderBrush" Color="#3B82F6" />
    
    <!-- 选中态 -->
    <SolidColorBrush x:Key="SelectedItemBackgroundBrush" Color="#2E3A4B" />
    <SolidColorBrush x:Key="SelectedItemBorderBrush" Color="#3B82F6" />
    
    <!-- 主操作按钮 (蓝色系) -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#E5E7EB" />

    <!-- 次要按钮 (跟随控制) -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#363639" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#4A4A4D" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#F3F4F6" />
    
    <!-- 危险操作按钮 (红色系) -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#DC2626" />
    
    <!-- 警告/执行中 (琥珀色) -->
    <SolidColorBrush x:Key="WarningButtonBackgroundBrush" Color="#F59E0B" />

    <!-- 终端背景与文字 -->
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="TerminalTextBrush" Color="#E6EDF3" />
</ResourceDictionary>
