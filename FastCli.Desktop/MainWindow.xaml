<Window x:Class="FastCli.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FastCli"
        Width="1500"
        Height="920"
        MinWidth="1240"
        MinHeight="760"
        Background="#F5F1E6"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Border" x:Key="PanelBorderStyle">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="#FFFDF9F2" />
            <Setter Property="BorderBrush" Value="#E2D8C7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#163A35" />
            <Setter Property="Foreground" Value="#FFF9F5EC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#CDBFA9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFCF7" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="#CDBFA9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFCF7" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="FastCli" FontSize="28" FontWeight="Bold" Foreground="#163A35" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#6B5F4B"
                               Text="Windows 命令工作台：分组管理、结构化编辑、嵌入日志和外部终端执行。" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#ECE5D8"
                        CornerRadius="14"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="状态" FontWeight="Bold" Foreground="#4A4032" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#5E5648" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="370" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="分组" FontSize="18" FontWeight="Bold" Foreground="#163A35" />
                        <StackPanel Margin="0,12,0,12" Orientation="Horizontal">
                            <Button Content="新建" Click="AddGroupButton_Click" />
                            <Button Content="重命名" Click="RenameGroupButton_Click" />
                            <Button Content="删除" Click="DeleteGroupButton_Click" Margin="0" Background="#A24B37" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox x:Name="GroupListBox"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             DisplayMemberPath="Name"
                             AllowDrop="True"
                             Background="Transparent"
                             BorderThickness="0"
                             PreviewMouseLeftButtonDown="GroupListBox_PreviewMouseLeftButtonDown"
                             MouseMove="GroupListBox_MouseMove"
                             Drop="GroupListBox_Drop"
                             DragOver="GroupListBox_DragOver" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="命令" FontSize="18" FontWeight="Bold" Foreground="#163A35" />
                        <StackPanel Margin="0,12,0,12" Orientation="Horizontal">
                            <Button Content="新建命令" Click="AddCommandButton_Click" IsEnabled="{Binding CanCreateCommand}" />
                            <Button Content="复制" Click="DuplicateCommandButton_Click" IsEnabled="{Binding CanEditCommand}" />
                            <Button Content="删除" Click="DeleteCommandButton_Click" IsEnabled="{Binding CanEditCommand}" Margin="0" Background="#A24B37" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox x:Name="CommandListBox"
                             ItemsSource="{Binding Commands}"
                             SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                             AllowDrop="True"
                             Background="Transparent"
                             BorderThickness="0"
                             PreviewMouseLeftButtonDown="CommandListBox_PreviewMouseLeftButtonDown"
                             MouseMove="CommandListBox_MouseMove"
                             Drop="CommandListBox_Drop"
                             DragOver="CommandListBox_DragOver"
                             MouseDoubleClick="CommandListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FFF8F2E8"
                                        BorderBrush="#E0D4C1"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="15" Text="{Binding Name}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#7A6A58"
                                                   Text="{Binding ShellType}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#4F4639"
                                                   Text="{Binding CommandText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="命令编辑" FontSize="18" FontWeight="Bold" Foreground="#163A35" />

                        <TextBlock Margin="0,16,0,6" Text="名称" FontWeight="Bold" />
                        <TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6" Text="说明" FontWeight="Bold" />
                        <TextBox Height="56"
                                 Text="{Binding EditedDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />

                        <TextBlock Margin="0,14,0,6" Text="工作目录" FontWeight="Bold" />
                        <TextBox Text="{Binding EditedWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Margin="0,0,0,6" Text="Shell 类型" FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding AvailableShellTypes}"
                                          SelectedItem="{Binding EditedShellType, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Margin="0,0,0,6" Text="执行方式" FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding AvailableRunModes}"
                                          SelectedItem="{Binding EditedRunMode, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Margin="0,14,0,0"
                                  Content="以管理员权限运行（V1 推荐搭配外部终端模式）"
                                  IsChecked="{Binding EditedRunAsAdministrator, Mode=TwoWay}" />

                        <TextBlock Margin="0,14,0,6" Text="命令内容" FontWeight="Bold" />
                        <TextBox Height="120"
                                 Text="{Binding EditedCommandText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Margin="0,14,0,6" Text="参数（每行一个）" FontWeight="Bold" />
                        <TextBox Height="86"
                                 Text="{Binding EditedArgumentsText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />

                        <DockPanel Margin="0,14,0,6">
                            <TextBlock DockPanel.Dock="Left" Text="环境变量" FontWeight="Bold" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="新增变量" Click="AddEnvironmentVariableButton_Click" />
                                <Button Content="删除变量" Click="RemoveEnvironmentVariableButton_Click" Margin="0" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid x:Name="EnvironmentVariablesGrid"
                                  Height="160"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  ItemsSource="{Binding EnvironmentVariables}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Key" Width="*" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="Value" Width="1.4*" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Margin="0,14,0,6" Text="命令预览" FontWeight="Bold" />
                        <TextBox Height="100"
                                 IsReadOnly="True"
                                 Text="{Binding CommandPreview, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <Button Content="保存命令" Click="SaveCommandButton_Click" IsEnabled="{Binding CanEditCommand}" />
                            <Button Content="立即运行" Click="RunCommandButton_Click" IsEnabled="{Binding CanRunCommand}" Background="#B45D28" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left" Text="执行日志与历史" FontSize="18" FontWeight="Bold" Foreground="#163A35" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="停止运行" Click="StopCommandButton_Click" IsEnabled="{Binding CanStopCommand}" Background="#A24B37" />
                        <Button Content="复制日志" Click="CopyLogButton_Click" />
                        <Button Content="清空显示" Click="ClearLogButton_Click" Margin="0" />
                    </StackPanel>
                </DockPanel>

                <ListBox Grid.Row="1"
                         Margin="0,0,16,0"
                         ItemsSource="{Binding ExecutionHistory}"
                         SelectedItem="{Binding SelectedHistoryRecord, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    Background="#FFF8F2E8"
                                    BorderBrush="#E0D4C1"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="{Binding StartedAt}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#6B5F4B" Text="{Binding Status}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#564B3C"
                                               Text="{Binding Summary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         IsReadOnly="True"
                         Text="{Binding CurrentLogText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</Window>
