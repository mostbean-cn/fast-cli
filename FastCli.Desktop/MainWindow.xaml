<Window x:Class="FastCli.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:FastCli.Desktop.Localization"
        xmlns:mvvm="clr-namespace:FastCli.Desktop.Mvvm"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{loc:Loc MainWindow_Title}" Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" 
        TextOptions.TextRenderingMode="ClearType" 
        FontFamily="Microsoft YaHei UI, Segoe UI Variable Display, Segoe UI, sans-serif"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <mvvm:ShellTypeDisplayConverter x:Key="ShellTypeDisplayConverter" />
        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarWidthKey}">8</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarHeightKey}">8</sys:Double>
        <!-- Styles using DynamicResource -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlFocusedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ModernComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    
                    <Path x:Name="arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" Stroke="{TemplateBinding Foreground}" StrokeThickness="2" Fill="Transparent" Stretch="None" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="arrow" Property="Data" Value="M0,4 L4,0 L8,4" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Foreground="{TemplateBinding Foreground}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Template="{StaticResource ModernComboBoxToggleButton}" Cursor="Hand" />
                            <ContentPresenter x:Name="contentPresenter" IsHitTestVisible="False" Margin="{TemplateBinding Padding}" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Margin="0,4,0,0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=toggleButton}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" Margin="0,4" CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryBorderlessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Padding" Value="4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="ButtonGlyphTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>
        <Style x:Key="ButtonLabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="0,2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource TertiaryTextBrush}" CornerRadius="3" Opacity="0.6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="SwitchBackground" Width="36" Height="20" CornerRadius="10" Background="{DynamicResource ControlBorderBrush}" BorderThickness="1" BorderBrush="{DynamicResource ControlBorderBrush}">
                                <Ellipse x:Name="SwitchThumb" Width="14" Height="14" Fill="{DynamicResource PanelBackgroundBrush}" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
                                <Setter TargetName="SwitchBackground" Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubtleGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="ShowsPreview" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/assets/FastCliHeader.png"
                           Width="24"
                           Height="24"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="FastCli" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TertiaryTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Click="OpenTerminalButton_Click"
                            IsEnabled="{Binding CanOpenTerminal}"
                            ToolTip="{loc:Loc MainWindow_OpenTerminalTooltip}"
                            Margin="0,0,8,0"
                            Padding="12,0"
                            Height="36">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE756;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                            <TextBlock Text="{loc:Loc MainWindow_OpenTerminal}" FontWeight="SemiBold" Style="{StaticResource ButtonLabelTextStyle}" />
                            <TextBlock Text="&#xE70D;" FontSize="12" Margin="6,0,0,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                                <MenuItem Header="{loc:Loc Shell_CmdOption}" Tag="Cmd" Click="OpenTerminalShellMenuItem_Click" />
                                <MenuItem Header="{loc:Loc Shell_PowerShellOption}" Tag="PowerShell" Click="OpenTerminalShellMenuItem_Click" />
                                <MenuItem Header="{loc:Loc Shell_PwshOption}" Tag="Pwsh" Click="OpenTerminalShellMenuItem_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Click="OpenSettingsButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Loc MainWindow_SettingsTooltip}">
                        <TextBlock Text="&#xE713;" FontSize="16" Style="{StaticResource ButtonGlyphTextStyle}" />
                    </Button>
                    <Button Content="{Binding ThemeIcon}" Click="ToggleThemeButton_Click" Style="{StaticResource IconButtonStyle}" FontSize="16" Margin="4,0,0,0" ToolTip="{loc:Loc MainWindow_ToggleThemeTooltip}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource ButtonGlyphTextStyle}" />
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid x:Name="WorkspaceContent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Left Sidebar (Groups + Commands) -->
                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="100"/>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1.5*" MinHeight="150" />
                        </Grid.RowDefinitions>
                    
                    <!-- Groups -->
                    <DockPanel Grid.Row="0" Margin="12">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                            <TextBlock Text="{loc:Loc MainWindow_Groups}" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Width="80"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="170" FlowDirection="RightToLeft">
                                <Button Click="DeleteGroupButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc Common_Delete}" Foreground="{DynamicResource DangerButtonBackgroundBrush}">
                                    <TextBlock Text="&#xE74D;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                                <Button Click="RenameGroupButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc Common_Rename}">
                                    <TextBlock Text="&#xE70F;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                                <Button Click="AddGroupButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc MainWindow_NewGroupTooltip}">
                                    <TextBlock Text="&#xE710;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <ListBox x:Name="GroupListBox" ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup, Mode=TwoWay}" DisplayMemberPath="Name" AllowDrop="True" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" PreviewMouseLeftButtonDown="GroupListBox_PreviewMouseLeftButtonDown" MouseMove="GroupListBox_MouseMove" Drop="GroupListBox_Drop" DragOver="GroupListBox_DragOver" />
                    </DockPanel>
                    
                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Cursor="SizeNS" Style="{StaticResource SubtleGridSplitterStyle}" />
                    
                    <!-- Commands -->
                    <DockPanel Grid.Row="2" Margin="12">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{loc:Loc MainWindow_Commands}" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Width="80" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="170" FlowDirection="RightToLeft">
                                <Button Click="DeleteCommandButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc Common_Delete}" Foreground="{DynamicResource DangerButtonBackgroundBrush}" IsEnabled="{Binding CanEditCommand}">
                                    <TextBlock Text="&#xE74D;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                                <Button Click="DuplicateCommandButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc Common_Duplicate}" IsEnabled="{Binding CanEditCommand}">
                                    <TextBlock Text="&#xE8C8;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                                <Button Click="AddCommandButton_Click" Style="{StaticResource SecondaryBorderlessButton}" ToolTip="{loc:Loc MainWindow_NewCommandTooltip}" IsEnabled="{Binding CanCreateCommand}">
                                    <TextBlock Text="&#xE710;" FontSize="14" Style="{StaticResource ButtonGlyphTextStyle}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <ListBox x:Name="CommandListBox" ItemsSource="{Binding Commands}" SelectedItem="{Binding SelectedCommand, Mode=TwoWay}" AllowDrop="True" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" PreviewMouseLeftButtonDown="CommandListBox_PreviewMouseLeftButtonDown" MouseMove="CommandListBox_MouseMove" Drop="CommandListBox_Drop" DragOver="CommandListBox_DragOver" MouseDoubleClick="CommandListBox_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource ShellTypeDisplayConverter}">
                                                        <Binding Path="ShellType" />
                                                        <Binding Path="CurrentLanguage" Source="{x:Static loc:LocalizationManager.Instance}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Padding="8,4"
                                                ToolTip="{loc:Loc MainWindow_StartTooltip}"
                                                Click="RunCommandFromListButton_Click"
                                                Style="{StaticResource SecondaryBorderlessButton}">
                                            <TextBlock Text="&#xE768;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                    </Grid>
                </Border>
                
                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" Cursor="SizeWE" Style="{StaticResource SubtleGridSplitterStyle}" />
                
                <!-- Right Area (Editor + Terminal) -->
                <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="EditorRowDefinition" Height="*" />
                    <RowDefinition x:Name="TerminalSplitterRowDefinition" Height="0" />
                    <RowDefinition x:Name="TerminalPanelRowDefinition" Height="0" MinHeight="0" />
                </Grid.RowDefinitions>
                
                <!-- Editor -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,12,24,10">
                        <DockPanel Width="800" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc MainWindow_EditCommand}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Click="SaveCommandButton_Click" IsEnabled="{Binding CanEditCommand}" Margin="0,0,8,0" Width="92" Padding="0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE74E;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Save}" FontWeight="Bold" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="RunCommandButton_Click" IsEnabled="{Binding CanRunCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="100" Padding="0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE768;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Run}" FontWeight="Bold" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="12,10,12,12">
                        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                            <Grid Margin="0,0,0,16" Width="800" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{loc:Loc MainWindow_CommandName}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc MainWindow_Description}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding EditedDescription, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20" Width="800" HorizontalAlignment="Left">
                                <TextBlock Text="{loc:Loc MainWindow_WorkingDirectory}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding EditedWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" ToolTip="{loc:Loc MainWindow_WorkingDirectoryTooltip}" />
                            </StackPanel>

                            <Grid Margin="0,0,0,20" Width="800" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{loc:Loc MainWindow_ShellType}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableShellTypes}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding EditedShellType, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc MainWindow_RunMode}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableRunModes}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding EditedRunMode, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                    <CheckBox Content="{loc:Loc MainWindow_RunAsAdministrator}"
                                              IsChecked="{Binding EditedRunAsAdministrator, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}"
                                              Style="{StaticResource ModernToggleSwitch}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20" Width="800" HorizontalAlignment="Left">
                                <TextBlock Text="{loc:Loc MainWindow_CommandText}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="150"
                                         Text="{Binding EditedCommandText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditCommand}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20" Width="800" HorizontalAlignment="Left">
                                <TextBlock Text="{loc:Loc MainWindow_Arguments}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="90"
                                         Text="{Binding EditedArgumentsText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditCommand}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20" Width="800" HorizontalAlignment="Left">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{loc:Loc MainWindow_EnvironmentVariables}" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Click="AddEnvironmentVariableButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource PrimaryButtonBackgroundBrush}" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE710;" Margin="0,0,4,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                <TextBlock Text="{loc:Loc Common_Add}" Style="{StaticResource ButtonLabelTextStyle}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="RemoveEnvironmentVariableButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource DangerButtonBackgroundBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74D;" Margin="0,0,4,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                <TextBlock Text="{loc:Loc Common_Delete}" Style="{StaticResource ButtonLabelTextStyle}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{loc:Loc MainWindow_EnvironmentVariablesHint}"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                           TextWrapping="Wrap" />

                                <Border BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource ControlBackgroundBrush}" Padding="10,10,6,10">
                                    <Grid Height="140">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Margin="0,0,18,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{loc:Loc MainWindow_EnvironmentKey}" Foreground="{DynamicResource TertiaryTextBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Grid.Column="2" Text="{loc:Loc MainWindow_EnvironmentValue}" Foreground="{DynamicResource TertiaryTextBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </Grid>

                                        <ListBox x:Name="EnvironmentVariablesGrid" Grid.Row="1" ItemsSource="{Binding EnvironmentVariables}" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Margin="0,0,0,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="EnvironmentVariablesGrid_PreviewMouseWheel">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <EventSetter Event="UIElement.GotKeyboardFocus" Handler="EnvironmentVariablesGrid_GotKeyboardFocus" />
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource ControlBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Background="{DynamicResource PanelBackgroundBrush}"
                                                            Padding="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="40" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding DataContext.CanEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Background="{DynamicResource WindowBackgroundBrush}"
                                                                     BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                     BorderThickness="1"
                                                                     Padding="8,6"
                                                                     ToolTip="{loc:Loc MainWindow_EnvironmentKeyTooltip}" />
                                                            <Border Grid.Column="1"
                                                                    Width="28"
                                                                    Height="28"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{DynamicResource SelectedItemBackgroundBrush}"
                                                                    CornerRadius="4">
                                                                <TextBlock Text="="
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold" />
                                                            </Border>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding DataContext.CanEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Background="{DynamicResource WindowBackgroundBrush}"
                                                                     BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                     BorderThickness="1"
                                                                     Padding="8,6"
                                                                     ToolTip="{loc:Loc MainWindow_EnvironmentValueTooltip}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16" Width="800" HorizontalAlignment="Left">
                                <TextBlock Text="{loc:Loc MainWindow_UserReadablePreview}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="90"
                                         IsReadOnly="True"
                                         Text="{Binding CommandPreview, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{DynamicResource ControlBackgroundBrush}"
                                         Foreground="{DynamicResource TertiaryTextBrush}"
                                         BorderBrush="{DynamicResource ControlBorderBrush}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,0" Width="800" HorizontalAlignment="Left">
                                <TextBlock Text="{loc:Loc MainWindow_ActualExecutionCommand}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="100"
                                         IsReadOnly="True"
                                         Text="{Binding ActualExecutionCommand, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{DynamicResource ControlBackgroundBrush}"
                                         Foreground="{DynamicResource TertiaryTextBrush}"
                                         BorderBrush="{DynamicResource ControlBorderBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <GridSplitter Grid.Row="1"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              Cursor="SizeNS"
                              Visibility="{Binding IsTerminalPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Style="{StaticResource SubtleGridSplitterStyle}" />
                
                <Grid Grid.Row="2"
                      Background="{DynamicResource TerminalBackgroundBrush}"
                      Visibility="{Binding IsTerminalPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,0,1">
                        <DockPanel Margin="16,8">
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Loc MainWindow_TerminalOutput}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" FontFamily="Consolas" />
                                    <TextBlock Text="{Binding TerminalSessionLabel}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Border Background="{DynamicResource SelectedItemBackgroundBrush}" CornerRadius="999" Padding="8,2">
                                        <TextBlock Text="{Binding TerminalSessionStatus}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="999" Padding="8,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding TerminalInputStatus}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Click="StopCommandButton_Click" IsEnabled="{Binding CanStopCommand}" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource DangerButtonBackgroundBrush}" Margin="0,0,8,0" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71A;" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Stop}" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="CopyLogButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Copy}" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearLogButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource SecondaryTextBrush}" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE894;" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Clear}" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="CloseTerminalPanelButton_Click"
                                        Style="{StaticResource SecondaryBorderlessButton}"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        ToolTip="{loc:Loc MainWindow_TerminalCloseTooltip}"
                                        Margin="8,0,0,0"
                                        Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Close}" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <wv2:WebView2 x:Name="TerminalWebView"
                                      Margin="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                        <Border x:Name="TerminalUnavailableOverlay"
                                Background="{DynamicResource TerminalBackgroundBrush}"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TerminalUnavailableText"
                                       Margin="20"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border x:Name="SettingsPageContainer"
                    Grid.ColumnSpan="3"
                    Visibility="Collapsed"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    Panel.ZIndex="10">
                <ContentControl x:Name="SettingsPageHost" />
            </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
