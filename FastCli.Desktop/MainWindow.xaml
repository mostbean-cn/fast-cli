<Window x:Class="FastCli.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:desktop="clr-namespace:FastCli.Desktop"
        xmlns:loc="clr-namespace:FastCli.Desktop.Localization"
        xmlns:mvvm="clr-namespace:FastCli.Desktop.Mvvm"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{loc:Loc MainWindow_Title}" Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" 
        TextOptions.TextRenderingMode="ClearType" 
        FontFamily="Microsoft YaHei UI, Segoe UI Variable Display, Segoe UI, sans-serif"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <mvvm:ShellTypeDisplayConverter x:Key="ShellTypeDisplayConverter" />
        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarWidthKey}">8</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarHeightKey}">8</sys:Double>
        <!-- Styles using DynamicResource -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlFocusedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ModernComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    
                    <Path x:Name="arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" Stroke="{TemplateBinding Foreground}" StrokeThickness="2" Fill="Transparent" Stretch="None" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="arrow" Property="Data" Value="M0,4 L4,0 L8,4" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Foreground="{TemplateBinding Foreground}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Template="{StaticResource ModernComboBoxToggleButton}" Cursor="Hand" />
                            <ContentPresenter x:Name="contentPresenter" IsHitTestVisible="False" Margin="{TemplateBinding Padding}" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Margin="0,6,0,0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=toggleButton}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" Margin="0,4" CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                    <Setter Property="Opacity" Value="0.94" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryBorderlessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="SummaryLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}" />
        </Style>
        <Style x:Key="SessionListLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource SummaryLinkButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TerminalStatusInlineButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="{DynamicResource ImmersiveTerminalBadgeBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                            <DataTrigger Binding="{Binding DataContext.IsImmersiveTerminalMode, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ImmersiveTerminalBadgeActiveBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ImmersiveTerminalBadgeActiveForegroundBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarHeaderToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarSectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SidebarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style x:Key="SidebarCollapseButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarActionButtonStyle}">
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style x:Key="SidebarGroupListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="{TemplateBinding Margin}">
                            <Border x:Name="ItemRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid Height="36">
                                    <ContentPresenter Margin="12,0,10,0"
                                                      VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border x:Name="InsertBeforeIndicator"
                                    Height="4"
                                    Margin="8,0,8,0"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource PrimaryButtonBackgroundBrush}"
                                    CornerRadius="999"
                                    Visibility="Collapsed" />
                            <Border x:Name="InsertAfterIndicator"
                                    Height="4"
                                    Margin="8,0,8,0"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource PrimaryButtonBackgroundBrush}"
                                    CornerRadius="999"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="Target">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="InsertBefore">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter TargetName="InsertBeforeIndicator" Property="Visibility" Value="Visible" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="InsertAfter">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter TargetName="InsertAfterIndicator" Property="Visibility" Value="Visible" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarCommandListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="{TemplateBinding Margin}">
                            <Border x:Name="ItemRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="10,8">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="InsertBeforeIndicator"
                                    Height="4"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource PrimaryButtonBackgroundBrush}"
                                    CornerRadius="999"
                                    Visibility="Collapsed" />
                            <Border x:Name="InsertAfterIndicator"
                                    Height="4"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource PrimaryButtonBackgroundBrush}"
                                    CornerRadius="999"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="Target">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="InsertBefore">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter TargetName="InsertBeforeIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="desktop:MainWindow.DragHint" Value="InsertAfter">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                                <Setter TargetName="ItemRoot" Property="BorderThickness" Value="1" />
                                <Setter TargetName="InsertAfterIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarRunButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarActionButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}" />
        </Style>
        <Style x:Key="ButtonGlyphTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>
        <Style x:Key="ButtonLabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>
        <Style x:Key="ImmersiveCollapsedBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsImmersiveTerminalMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImmersiveToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryBorderlessButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsImmersiveTerminalMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Width" Value="28" />
                    <Setter Property="Height" Value="28" />
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Padding" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImmersiveToolbarIconTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonGlyphTextStyle}">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsImmersiveTerminalMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImmersiveToolbarLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonLabelTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsImmersiveTerminalMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TerminalShellContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TerminalShellMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="ToolTip" Value="{Binding Description}" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid Width="156">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE756;"
                                       Width="18"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Label}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="8,7">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="Click" Handler="OpenTerminalShellMenuItem_Click" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedItemBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource TertiaryTextBrush}" CornerRadius="3" Opacity="0.6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="SwitchBackground" Width="36" Height="20" CornerRadius="10" Background="{DynamicResource ControlBorderBrush}" BorderThickness="1" BorderBrush="{DynamicResource ControlBorderBrush}">
                                <Ellipse x:Name="SwitchThumb" Width="14" Height="14" Fill="{DynamicResource PanelBackgroundBrush}" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
                                <Setter TargetName="SwitchBackground" Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubtleGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="ShowsPreview" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRowDefinition" Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border x:Name="HeaderContainerBorder"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="ToggleSidebarCollapseButton_Click"
                            Style="{StaticResource SidebarHeaderToggleButtonStyle}"
                            ToolTip="{Binding SidebarToggleToolTip}"
                            Margin="0,0,8,0">
                        <Grid Width="14" Height="14">
                            <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    BorderThickness="1"
                                    CornerRadius="3" />
                            <Border Width="3"
                                    Margin="2,2,0,2"
                                    HorizontalAlignment="Left"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    CornerRadius="1" />
                            <Border Width="1"
                                    Margin="6,2,0,2"
                                    HorizontalAlignment="Left"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Opacity="0.45" />
                        </Grid>
                    </Button>
                    <TextBlock Text="FastCli" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Grid Margin="12,1,0,0">
                        <Button x:Name="InternalTerminalSummaryButton"
                                Click="InternalTerminalSummaryButton_Click"
                                Style="{StaticResource SummaryLinkButtonStyle}">
                            <TextBlock Text="{Binding InternalTerminalSummaryText}"
                                       FontSize="12"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Popup x:Name="InternalTerminalSessionsPopup"
                               PlacementTarget="{Binding ElementName=InternalTerminalSummaryButton}"
                               Placement="Bottom"
                               HorizontalOffset="-8"
                               VerticalOffset="10"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Width="380"
                                    Padding="12"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc MainWindow_InternalTerminalSessionManagerTitle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10" />
                                    <ScrollViewer MaxHeight="320"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding InternalTerminalSessionItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="SessionItemBorder"
                                                            Margin="0,0,0,8"
                                                            Padding="8"
                                                            CornerRadius="8"
                                                            Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0"
                                                                    Click="ActivateInternalTerminalSessionButton_Click"
                                                                    Tag="{Binding SessionId}"
                                                                    Style="{StaticResource SessionListLinkButtonStyle}"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="0">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding GroupName}"
                                                                               FontSize="10.5"
                                                                               Foreground="{DynamicResource TertiaryTextBrush}"
                                                                               Margin="0,0,0,3">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasGroupName}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock x:Name="CurrentSessionBadge"
                                                                                   Text="{loc:Loc MainWindow_InternalTerminalSessionCurrent}"
                                                                                   Margin="8,0,0,0"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource PrimaryButtonBackgroundBrush}"
                                                                                   Visibility="Collapsed" />
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                        <Border x:Name="SessionStatusBadge"
                                                                                Padding="6,2"
                                                                                CornerRadius="6"
                                                                                Background="{DynamicResource ControlBackgroundBrush}">
                                                                            <TextBlock x:Name="SessionStatusText"
                                                                                       Text="{Binding StatusText}"
                                                                                       FontSize="10.5"
                                                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Subtitle}"
                                                                                   Margin="8,0,0,0"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Grid.Column="1"
                                                                    Click="CloseInternalTerminalSessionButton_Click"
                                                                    Tag="{Binding SessionId}"
                                                                    Style="{StaticResource SecondaryBorderlessButton}"
                                                                    ToolTip="{loc:Loc MainWindow_TerminalCloseTooltip}"
                                                                    Width="28"
                                                                    Height="28"
                                                                    Padding="0"
                                                                    Margin="8,0,0,0">
                                                                <TextBlock Text="&#xE711;" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter TargetName="SessionItemBorder" Property="Background" Value="{DynamicResource SelectedItemBackgroundBrush}" />
                                                            <Setter TargetName="CurrentSessionBadge" Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter TargetName="SessionStatusText" Property="Foreground" Value="{DynamicResource AnsiGreen}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TertiaryTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Click="OpenTerminalButton_Click"
                            IsEnabled="{Binding CanOpenTerminal}"
                            Style="{StaticResource SecondaryBorderlessButton}"
                            ToolTip="{Binding OpenTerminalButtonToolTip}"
                            Margin="0,0,8,0"
                            Padding="12,0"
                            Height="36">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE756;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                            <TextBlock Text="{Binding OpenTerminalButtonText}" FontWeight="SemiBold" Style="{StaticResource ButtonLabelTextStyle}" />
                            <TextBlock Text="&#xE70D;" FontSize="12" Margin="6,0,0,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource TerminalShellContextMenuStyle}"
                                         ItemContainerStyle="{StaticResource TerminalShellMenuItemStyle}"
                                         ItemsSource="{Binding AvailableTerminalShellTypes}">
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Click="OpenSettingsButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Loc MainWindow_SettingsTooltip}">
                        <TextBlock Text="&#xE713;" FontSize="16" Style="{StaticResource ButtonGlyphTextStyle}" />
                    </Button>
                    <Button Content="{Binding ThemeIcon}" Click="ToggleThemeButton_Click" Style="{StaticResource IconButtonStyle}" FontSize="16" Margin="4,0,0,0" ToolTip="{loc:Loc MainWindow_ToggleThemeTooltip}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource ButtonGlyphTextStyle}" />
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid x:Name="WorkspaceContent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumnDefinition" Width="280" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Left Sidebar (Groups + Commands) -->
                <Border x:Name="SidebarContainerBorder" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid x:Name="ExpandedSidebarHost">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid Margin="12,14,12,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="SidebarGroupsRowDefinition" Height="*" />
                                    <RowDefinition x:Name="SidebarSectionSplitterRowDefinition" Height="Auto" />
                                    <RowDefinition x:Name="SidebarCommandsRowDefinition" Height="1.5*" />
                                </Grid.RowDefinitions>

                                <!-- Groups -->
                                <DockPanel Grid.Row="0">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Loc MainWindow_Groups}"
                                                   Style="{StaticResource SidebarSectionTitleTextStyle}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Click="AddGroupButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc MainWindow_NewGroupTooltip}">
                                                <TextBlock Text="&#xE710;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="RenameGroupButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc Common_Rename}">
                                                <TextBlock Text="&#xE70F;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="DeleteGroupButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc Common_Delete}" Foreground="{DynamicResource DangerButtonBackgroundBrush}">
                                                <TextBlock Text="&#xE74D;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="ToggleGroupsSectionButton_Click"
                                                    Style="{StaticResource SidebarCollapseButtonStyle}"
                                                    ToolTip="{Binding GroupsSectionToggleToolTip}"
                                                    Foreground="{DynamicResource SecondaryTextBrush}">
                                                <TextBlock Text="{Binding GroupsSectionToggleGlyph}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <ListBox x:Name="GroupListBox"
                                             ItemsSource="{Binding Groups}"
                                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                             DisplayMemberPath="Name"
                                             AllowDrop="True"
                                             Background="Transparent"
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SidebarGroupListItemStyle}"
                                             Margin="0,2,0,0"
                                             PreviewMouseLeftButtonDown="GroupListBox_PreviewMouseLeftButtonDown"
                                             MouseMove="GroupListBox_MouseMove"
                                             Drop="GroupListBox_Drop"
                                             DragLeave="GroupListBox_DragLeave"
                                             DragOver="GroupListBox_DragOver">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGroupsSectionCollapsed}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                    </ListBox>
                                </DockPanel>

                                <GridSplitter x:Name="SidebarSectionGridSplitter"
                                              Grid.Row="1"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              Cursor="SizeNS"
                                              Style="{StaticResource SubtleGridSplitterStyle}" />

                                <!-- Commands -->
                                <DockPanel Grid.Row="2">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Loc MainWindow_Commands}"
                                                   Style="{StaticResource SidebarSectionTitleTextStyle}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Click="AddCommandButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc MainWindow_NewCommandTooltip}" IsEnabled="{Binding CanCreateCommand}">
                                                <TextBlock Text="&#xE710;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="DuplicateCommandButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc Common_Duplicate}" IsEnabled="{Binding CanEditCommand}">
                                                <TextBlock Text="&#xE8C8;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="DeleteCommandButton_Click" Style="{StaticResource SidebarActionButtonStyle}" ToolTip="{loc:Loc Common_Delete}" Foreground="{DynamicResource DangerButtonBackgroundBrush}" IsEnabled="{Binding CanEditCommand}">
                                                <TextBlock Text="&#xE74D;" FontSize="12" Style="{StaticResource ButtonGlyphTextStyle}" />
                                            </Button>
                                            <Button Click="ToggleCommandsSectionButton_Click"
                                                    Style="{StaticResource SidebarCollapseButtonStyle}"
                                                    ToolTip="{Binding CommandsSectionToggleToolTip}"
                                                    Foreground="{DynamicResource SecondaryTextBrush}">
                                                <TextBlock Text="{Binding CommandsSectionToggleGlyph}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <ListBox x:Name="CommandListBox"
                                             ItemsSource="{Binding Commands}"
                                             SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                                             AllowDrop="True"
                                             Background="Transparent"
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SidebarCommandListItemStyle}"
                                             Margin="0,2,0,0"
                                             PreviewMouseLeftButtonDown="CommandListBox_PreviewMouseLeftButtonDown"
                                             MouseMove="CommandListBox_MouseMove"
                                             Drop="CommandListBox_Drop"
                                             DragLeave="CommandListBox_DragLeave"
                                             DragOver="CommandListBox_DragOver"
                                             MouseDoubleClick="CommandListBox_MouseDoubleClick">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCommandsSectionCollapsed}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,1,0,0">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource ShellTypeDisplayConverter}">
                                                                    <Binding Path="ShellType" />
                                                                    <Binding Path="CurrentLanguage" Source="{x:Static loc:LocalizationManager.Instance}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Padding="0"
                                                            ToolTip="{loc:Loc MainWindow_StartTooltip}"
                                                            Click="RunCommandFromListButton_Click"
                                                            IsEnabled="{Binding DataContext.CanRunCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Style="{StaticResource SidebarRunButtonStyle}">
                                                        <TextBlock Text="&#xE768;" FontSize="10" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
                
                <GridSplitter x:Name="SidebarColumnSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Center" Cursor="SizeWE" Style="{StaticResource SubtleGridSplitterStyle}" />
                
                <!-- Right Area (Editor + Terminal) -->
                <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="EditorRowDefinition" Height="*" />
                    <RowDefinition x:Name="TerminalSplitterRowDefinition" Height="0" />
                    <RowDefinition x:Name="TerminalPanelRowDefinition" Height="0" MinHeight="0" />
                </Grid.RowDefinitions>
                
                <!-- Editor -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource TitleBarBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,12,24,10">
                        <DockPanel MaxWidth="1280"
                                   HorizontalAlignment="Stretch">
                            <TextBlock Text="{loc:Loc MainWindow_EditCommand}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Click="SaveCommandButton_Click" IsEnabled="{Binding CanEditCommand}" Margin="0,0,8,0" Width="92" Padding="0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE74E;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Save}" FontWeight="Bold" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="RunCommandButton_Click" IsEnabled="{Binding CanRunCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="100" Padding="0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE768;" FontSize="14" Margin="0,0,6,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Run}" FontWeight="Bold" Style="{StaticResource ButtonLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="12,10,12,12"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="1280"
                                    HorizontalAlignment="Stretch">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{loc:Loc MainWindow_CommandName}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc MainWindow_Description}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding EditedDescription, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="{loc:Loc MainWindow_WorkingDirectory}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding EditedWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCommand}" ToolTip="{loc:Loc MainWindow_WorkingDirectoryTooltip}" />
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{loc:Loc MainWindow_ShellType}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableShellTypes}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding EditedShellType, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc MainWindow_RunMode}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <ComboBox ItemsSource="{Binding AvailableRunModes}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding EditedRunMode, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                    <CheckBox Content="{loc:Loc MainWindow_RunAsAdministrator}"
                                              IsChecked="{Binding EditedRunAsAdministrator, Mode=TwoWay}"
                                              IsEnabled="{Binding CanEditCommand}"
                                              Style="{StaticResource ModernToggleSwitch}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="{loc:Loc MainWindow_CommandText}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="150"
                                         Text="{Binding EditedCommandText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditCommand}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="{loc:Loc MainWindow_Arguments}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="90"
                                         Text="{Binding EditedArgumentsText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditCommand}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{loc:Loc MainWindow_EnvironmentVariables}" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Click="AddEnvironmentVariableButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource PrimaryButtonBackgroundBrush}" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE710;" Margin="0,0,4,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                <TextBlock Text="{loc:Loc Common_Add}" Style="{StaticResource ButtonLabelTextStyle}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="RemoveEnvironmentVariableButton_Click" Style="{StaticResource SecondaryBorderlessButton}" Foreground="{DynamicResource DangerButtonBackgroundBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74D;" Margin="0,0,4,0" Style="{StaticResource ButtonGlyphTextStyle}" />
                                                <TextBlock Text="{loc:Loc Common_Delete}" Style="{StaticResource ButtonLabelTextStyle}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{loc:Loc MainWindow_EnvironmentVariablesHint}"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                           TextWrapping="Wrap" />

                                <Border BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource ControlBackgroundBrush}" Padding="10,10,6,10">
                                    <Grid Height="140">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Margin="0,0,18,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{loc:Loc MainWindow_EnvironmentKey}" Foreground="{DynamicResource TertiaryTextBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Grid.Column="2" Text="{loc:Loc MainWindow_EnvironmentValue}" Foreground="{DynamicResource TertiaryTextBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </Grid>

                                        <ListBox x:Name="EnvironmentVariablesGrid" Grid.Row="1" ItemsSource="{Binding EnvironmentVariables}" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Margin="0,0,0,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="EnvironmentVariablesGrid_PreviewMouseWheel">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <EventSetter Event="UIElement.GotKeyboardFocus" Handler="EnvironmentVariablesGrid_GotKeyboardFocus" />
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource ControlBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Background="{DynamicResource ControlHoverBrush}"
                                                            Padding="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="40" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding DataContext.CanEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Background="{DynamicResource PanelBackgroundBrush}"
                                                                     BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                     BorderThickness="1"
                                                                     Padding="8,6"
                                                                     ToolTip="{loc:Loc MainWindow_EnvironmentKeyTooltip}" />
                                                            <Border Grid.Column="1"
                                                                    Width="28"
                                                                    Height="28"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{DynamicResource SelectedItemBackgroundBrush}"
                                                                    CornerRadius="6">
                                                                <TextBlock Text="="
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold" />
                                                            </Border>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding DataContext.CanEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Background="{DynamicResource PanelBackgroundBrush}"
                                                                     BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                     BorderThickness="1"
                                                                     Padding="8,6"
                                                                     ToolTip="{loc:Loc MainWindow_EnvironmentValueTooltip}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{loc:Loc MainWindow_UserReadablePreview}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="90"
                                         IsReadOnly="True"
                                         Text="{Binding CommandPreview, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{DynamicResource ControlBackgroundBrush}"
                                         Foreground="{DynamicResource TertiaryTextBrush}"
                                         BorderBrush="{DynamicResource ControlBorderBrush}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="{loc:Loc MainWindow_ActualExecutionCommand}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBox FontFamily="Consolas"
                                         Height="100"
                                         IsReadOnly="True"
                                         Text="{Binding ActualExecutionCommand, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{DynamicResource ControlBackgroundBrush}"
                                         Foreground="{DynamicResource TertiaryTextBrush}"
                                         BorderBrush="{DynamicResource ControlBorderBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <GridSplitter Grid.Row="1"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              Cursor="SizeNS"
                              Visibility="{Binding IsTerminalPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Style="{StaticResource SubtleGridSplitterStyle}" />
                
                <Grid Grid.Row="2"
                      Background="{DynamicResource TerminalBackgroundBrush}"
                      Visibility="{Binding IsTerminalPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TerminalHeaderRowDefinition" Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,0,1">
                        <DockPanel x:Name="TerminalHeaderDockPanel" Margin="14,5">
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImmersiveTerminalMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{loc:Loc MainWindow_TerminalOutput}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" FontFamily="Consolas" />
                                    <TextBlock Text="{Binding TerminalSessionLabel}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Margin" Value="0,6,0,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImmersiveTerminalMode}" Value="True">
                                                            <Setter Property="Margin" Value="0,1,0,0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                    <Border Background="{DynamicResource SelectedItemBackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="8,2"
                                            Style="{StaticResource ImmersiveCollapsedBadgeStyle}">
                                        <TextBlock Text="{Binding TerminalSessionStatus}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="8,2"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ImmersiveCollapsedBadgeStyle}">
                                        <TextBlock Text="{Binding TerminalInputStatus}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <Button Click="ToggleImmersiveTerminalButton_Click"
                                            IsEnabled="{Binding CanToggleImmersiveTerminal}"
                                            Style="{StaticResource TerminalStatusInlineButtonStyle}"
                                            ToolTip="{Binding ImmersiveTerminalButtonToolTip}"
                                            Margin="8,0,0,0"
                                            Padding="8,2">
                                        <TextBlock Text="{loc:Loc MainWindow_TerminalImmersiveEnter}"
                                                   FontSize="11"
                                                   Margin="0,-1,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                    <Button Click="InternalTerminalSummaryButton_Click"
                                            ToolTip="{loc:Loc MainWindow_InternalTerminalSessionManagerTitle}"
                                            Margin="8,0,0,0"
                                            Padding="8,2">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SummaryLinkButtonStyle}">
                                                <Setter Property="MinHeight" Value="24" />
                                                <Setter Property="Height" Value="24" />
                                                <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImmersiveTerminalMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding InternalTerminalSummaryText}"
                                                   FontSize="11"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding IsCommandTerminalSwitcherVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button Click="SwitchPreviousTerminalSessionButton_Click"
                                            IsEnabled="{Binding CanSwitchToPreviousCommandTerminalSession}"
                                            Style="{StaticResource ImmersiveToolbarButtonStyle}"
                                            ToolTip="{loc:Loc MainWindow_PreviousTerminalSessionTooltip}"
                                            Width="24"
                                            Height="24"
                                            Padding="0">
                                        <TextBlock Text="&#xE76B;" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                    </Button>
                                    <Button Click="ToggleTerminalSessionSwitcherScopeButton_Click"
                                            Style="{StaticResource SummaryLinkButtonStyle}"
                                            ToolTip="{loc:Loc MainWindow_TerminalSessionSwitcherToggleTooltip}"
                                            Padding="0"
                                            Margin="6,0">
                                        <TextBlock Text="{Binding CommandTerminalSessionSwitcherText}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                    <Button Click="SwitchNextTerminalSessionButton_Click"
                                            IsEnabled="{Binding CanSwitchToNextCommandTerminalSession}"
                                            Style="{StaticResource ImmersiveToolbarButtonStyle}"
                                            ToolTip="{loc:Loc MainWindow_NextTerminalSessionTooltip}"
                                            Width="24"
                                            Height="24"
                                            Padding="0">
                                        <TextBlock Text="&#xE76C;" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                    </Button>
                                </StackPanel>
                                <Button Click="StopCommandButton_Click" IsEnabled="{Binding CanStopCommand}" Style="{StaticResource ImmersiveToolbarButtonStyle}" Foreground="{DynamicResource DangerButtonBackgroundBrush}" Margin="0,0,8,0" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71A;" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Stop}" Style="{StaticResource ImmersiveToolbarLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="RefreshTerminalButton_Click" Style="{StaticResource ImmersiveToolbarButtonStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Refresh}" Style="{StaticResource ImmersiveToolbarLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ToggleTerminalMaximizeButton_Click"
                                        IsEnabled="{Binding CanToggleTerminalMaximize}"
                                        Style="{StaticResource ImmersiveToolbarButtonStyle}"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        ToolTip="{Binding TerminalMaximizeToolTip}"
                                        Margin="0,0,8,0"
                                        Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TerminalMaximizeGlyph}" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                        <TextBlock Text="{Binding TerminalMaximizeButtonText}" Style="{StaticResource ImmersiveToolbarLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="CloseTerminalPanelButton_Click"
                                        Style="{StaticResource ImmersiveToolbarButtonStyle}"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        ToolTip="{loc:Loc MainWindow_TerminalCloseTooltip}"
                                        Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" Style="{StaticResource ImmersiveToolbarIconTextStyle}" />
                                        <TextBlock Text="{loc:Loc Common_Close}" Style="{StaticResource ImmersiveToolbarLabelTextStyle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <wv2:WebView2 x:Name="TerminalWebView"
                                      Margin="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                        <Border x:Name="TerminalUnavailableOverlay"
                                Background="{DynamicResource TerminalBackgroundBrush}"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TerminalUnavailableText"
                                       Margin="20"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border x:Name="SettingsPageContainer"
                    Grid.ColumnSpan="3"
                    Visibility="Collapsed"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    Panel.ZIndex="10">
                <ContentControl x:Name="SettingsPageHost" />
            </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
